# Copy to `.env` and fill in. `.env` is gitignored.

# ─── Runtime ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
PUBLIC_URL=http://localhost:3002

# ─── Database (SQLite via Prisma) ─────────────────────────────────────────
DATABASE_URL=file:./prisma/dev.db

# ─── Sessions / cookies ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=change-me-to-a-long-random-hex-string
SESSION_MAX_AGE_MS=2592000000   # 30 days
COOKIE_SECURE=false             # set true in production behind HTTPS

# ─── Auth ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
SIGNUP_REQUIRES_INVITE=true
EMAIL_VERIFICATION_REQUIRED=true

# ─── Mail (SMTP) ──────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to print mails to the log instead (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="mcsw <noreply@example.com>"

# ─── mcsm peers ───────────────────────────────────────────────────────────
# Bootstrap peers loaded into the DB on first run if the table is empty.
# Format: name|url|token, comma-separated. Optional — peers can also be
# added through the admin UI.
MCSM_BOOTSTRAP=
# LAN scan: discover mcsm daemons on the local subnet.
MCSM_SCAN_ENABLED=true
MCSM_SCAN_PORTS=8124           # comma-separated; default mcsm port
MCSM_SCAN_INTERVAL_MS=300000   # 5 minutes
